generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Authentication
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  phone     String?  @unique
  password  String
  otp       String?
  otpExpiry DateTime?
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  entity    String?
  entityId  Int?
  createdAt DateTime @default(now())
}

// 2. Partners
model Partner {
  id           Int       @id @default(autoincrement())
  name         String
  type         String
  vatNumber    String?   @unique
  address      String?
  phone        String?
  email        String?
  balance      Float     @default(0.0)
  creditLimit  Float?
  
  invoices     Invoice[]
  quotes       Quote[]
  payments     Payment[]
  projects     Project[]
  contracts    RealEstateContract[]
  constructionContracts ConstructionContract[] @relation(name: "ClientContracts")
  documents    Document[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// 9. Quotes
model Quote {
  id            Int       @id @default(autoincrement())
  quoteNumber   String    @unique
  date          DateTime  @default(now())
  validUntil    DateTime?
  
  status        String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, INVOICED
  
  partnerId     Int?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  
  subtotal      Float
  taxAmount     Float
  discount      Float     @default(0)
  total         Float
  
  notes         String?
  
  items         QuoteItem[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model QuoteItem {
  id          Int       @id @default(autoincrement())
  quoteId     Int
  quote       Quote     @relation(fields: [quoteId], references: [id])
  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  taxRate     Float     @default(0.15)
  total       Float
}


// 3. Accounting
model Account {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  type          String
  parentId      Int?
  parent        Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[] @relation("AccountHierarchy")
  balance       Float     @default(0.0)
  entries       JournalEntry[]
  isActive      Boolean   @default(true)
}

model Transaction {
  id            Int       @id @default(autoincrement())
  date          DateTime  @default(now())
  description   String?
  reference     String?
  type          String
  entries       JournalEntry[]
  createdAt     DateTime  @default(now())
}

model JournalEntry {
  id            Int       @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  accountId     Int
  account       Account     @relation(fields: [accountId], references: [id])
  debit         Float       @default(0.0)
  credit        Float       @default(0.0)
  description   String?
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // LOW_STOCK, PROJECT_DEADLINE, INVOICE_OVERDUE
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// 4. Inventory
model Warehouse {
  id          Int       @id @default(autoincrement())
  name        String
  location    String?
  stocks      Stock[]
  movements   StockMovement[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  products    Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  name        String
  sku         String?   @unique
  barcode     String?   @unique
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  description String?
  price       Float
  cost        Float
  taxRate     Float     @default(0.15)
  unit        String    @default("PCS")
  
  stocks      Stock[]
  movements   StockMovement[]
  invoiceItems InvoiceItem[]
  quoteItems  QuoteItem[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Stock {
  id          Int       @id @default(autoincrement())
  productId   Int
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0)

  @@unique([productId, warehouseId])
}

model StockMovement {
  id          Int       @id @default(autoincrement())
  productId   Int
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float
  type        String
  reference   String?
  date        DateTime  @default(now())
}

// 5. Invoices
model Invoice {
  id            Int       @id @default(autoincrement())
  invoiceNumber String    @unique
  uuid          String    @unique
  date          DateTime  @default(now())
  dueDate       DateTime?
  
  type          String
  status        String    @default("DRAFT")
  
  partnerId     Int?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  
  subtotal      Float
  taxAmount     Float
  discount      Float     @default(0)
  total         Float

  hash          String?
  previousHash  String?
  zatcaStatus   String?
  qrCode        String?
  xmlContent    String?

  items         InvoiceItem[]
  payments      Payment[]
  
  projectId     Int?
  project       Project?  @relation(fields: [projectId], references: [id])
  
  contractId    Int?
  contract      RealEstateContract? @relation(fields: [contractId], references: [id])
  
  constructionContractId Int?
  constructionContract   ConstructionContract? @relation(fields: [constructionContractId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model InvoiceItem {
  id          Int       @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  taxRate     Float     @default(0.15)
  total       Float
}

// 6. Projects
model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("PLANNED")
  
  clientId    Int
  client      Partner   @relation(fields: [clientId], references: [id])
  
  contractValue Float
  expenses      Float     @default(0)
  
  invoices    Invoice[]
  tasks       Task[]
  documents   Document[]
  siteVisits  SiteVisit[]
  
  constructionContract ConstructionContract?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id          Int       @id @default(autoincrement())
  taskNumber  String?   @unique
  title       String
  description String?
  type        String    @default("OFFICE") // FIELD, OFFICE
  status      String    @default("NEW") // NEW, IN_PROGRESS, PENDING_CLOSURE, CLOSED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  phase       String?   // FOUNDATION, STRUCTURE, ISOLATION, FINISHING, ELECTRICAL, MECHANICAL, ARCHITECTURAL
  sbcClause   String?
  riskLevel   String    @default("LOW") // CRITICAL, MEDIUM, LOW
  
  dueDate     DateTime?
  
  projectId   Int?
  project     Project?  @relation(fields: [projectId], references: [id])
  
  assignedTo  String?
  engineerId  Int?
  engineer    Employee? @relation(fields: [engineerId], references: [id])
  
  measurements Json?
  engineerNotes String? @db.Text
  gpsLocation   String?
  supervisorSignature String? @db.Text
  contractorSignature String? @db.Text

  attachments   TaskAttachment[]
  tickets       Ticket[]
  risks         Risk[]
  aiReports     AIReport[]
  planComparisons PlanComparison[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// -- Field Operations & AI Related Models --

model TaskAttachment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])
  fileUrl   String
  fileType  String   // IMAGE, VIDEO, PDF, AUDIO, PANORAMA_360
  name      String?
  createdAt DateTime @default(now())
}

model Ticket {
  id          Int      @id @default(autoincrement())
  taskId      Int
  task        Task     @relation(fields: [taskId], references: [id])
  title       String
  description String?  @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteVisit {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  engineerId  Int
  engineer    Employee @relation(fields: [engineerId], references: [id])
  date        DateTime @default(now())
  notes       String?  @db.Text
  gpsLocation String?
  createdAt   DateTime @default(now())
}

model Risk {
  id             Int      @id @default(autoincrement())
  taskId         Int?
  task           Task?    @relation(fields: [taskId], references: [id])
  description    String   @db.Text
  severity       String   @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  mitigationPlan String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EngineerScore {
  id                  Int      @id @default(autoincrement())
  engineerId          Int
  engineer            Employee @relation(fields: [engineerId], references: [id])
  month               Int
  year                Int
  tasksCompletedScore Float    @default(0)
  closureSpeedScore   Float    @default(0)
  reportQualityScore  Float    @default(0)
  aiAccuracyScore     Float    @default(0)
  attendanceScore     Float    @default(0)
  finalScore          Float    @default(0)
  createdAt           DateTime @default(now())
  
  @@unique([engineerId, month, year])
}

model AIReport {
  id                Int      @id @default(autoincrement())
  taskId            Int
  task              Task     @relation(fields: [taskId], references: [id])
  imageUrl          String
  analysisResult    Json?    // violations, cracks, etc
  progressExtracted Float?
  sbcViolations     String?  @db.Text
  createdAt         DateTime @default(now())
}

model PlanComparison {
  id                 Int      @id @default(autoincrement())
  taskId             Int
  task               Task     @relation(fields: [taskId], references: [id])
  planUrl            String
  siteImageUrl       String
  differenceMapUrl   String?
  progressPercentage Float?
  createdAt          DateTime @default(now())
}



// 7. Real Estate
model Property {
  id          Int       @id @default(autoincrement())
  name        String
  code        String?   @unique
  type        String
  address     String?
  units       Unit[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Unit {
  id          Int       @id @default(autoincrement())
  propertyId  Int
  property    Property  @relation(fields: [propertyId], references: [id])
  unitNumber  String
  floor       String?
  type        String
  status      String    @default("VACANT")
  
  contracts   RealEstateContract[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RealEstateContract {
  id          Int       @id @default(autoincrement())
  contractNumber String @unique
  unitId      Int
  unit        Unit      @relation(fields: [unitId], references: [id])
  tenantId    Int
  tenant      Partner   @relation(fields: [tenantId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  rentAmount  Float
  paymentFrequency String
  
  status      String    @default("ACTIVE")
  payments    Payment[]
  invoices    Invoice[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 8. Payments
model Payment {
  id            Int       @id @default(autoincrement())
  date          DateTime  @default(now())
  amount        Float
  type          String
  method        String
  reference     String?
  
  partnerId     Int?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  
  invoiceId     Int?
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id])
  
  contractId    Int?
  contract      RealEstateContract? @relation(fields: [contractId], references: [id])
  
  notes         String?
  createdAt     DateTime  @default(now())
}

// 10. HR
model Employee {
  id          Int       @id @default(autoincrement())
  employeeId  String    @unique
  name        String
  jobTitle    String
  department  String?
  phone       String?
  email       String?
  salary      Float
  status      String    @default("ACTIVE") // ACTIVE, ON_LEAVE, TERMINATED
  joinDate    DateTime?
  
  salaries    SalaryRecord[]
  documents   Document[]
  
  // Field Operations Relations
  tasks       Task[]
  siteVisits  SiteVisit[]
  scores      EngineerScore[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SalaryRecord {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  month       Int
  year        Int
  baseSalary  Float
  allowances  Float     @default(0)
  deductions  Float     @default(0)
  netSalary   Float
  paymentDate DateTime  @default(now())
  status      String    @default("PAID")
}

// 12. Documents & Archive
model Document {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   // CONTRACT, ID, LICENSE, OTHER
  fileUrl     String
  fileType    String?
  fileSize    Int?
  
  // Relations (Optional)
  partnerId   Int?
  partner     Partner? @relation(fields: [partnerId], references: [id])
  
  employeeId  Int?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id])

  constructionContractId Int?
  constructionContract   ConstructionContract? @relation(fields: [constructionContractId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  updatedAt   DateTime @updatedAt
}

// 13. Construction Contracts (SCA & Saudi Standards)
model ConstructionContract {
  id              Int       @id @default(autoincrement())
  contractNumber  String    @unique
  title           String
  type            String    // MAIN, RENOVATION, DESIGN, LABOR, SUPPLY
  status          String    @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  
  partnerId       Int
  partner         Partner   @relation(name: "ClientContracts", fields: [partnerId], references: [id])
  
  projectId       Int?      @unique
  project         Project?  @relation(fields: [projectId], references: [id])
  
  startDate       DateTime
  endDate         DateTime
  totalValue      Float
  taxAmount       Float
  netValue        Float
  
  advancePayment  Float     @default(0)
  retentionPercent Float    @default(0)
  
  location        String?   // موقع التنفيذ
  signatureName   String?   // اسم المفوض
  
  // SCA Standard Clauses
  clauses         Json?     
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  items           ConstructionContractItem[]
  invoices        Invoice[]
  documents       Document[]
}

model ConstructionContractItem {
  id          Int       @id @default(autoincrement())
  contractId  Int
  contract    ConstructionContract @relation(fields: [contractId], references: [id])
  description String
  unit        String
  quantity    Float
  unitPrice   Float
  total       Float
}
