{
    "version": 2,
    "buildCommand": "npm run build --prefix client",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "server/src/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}