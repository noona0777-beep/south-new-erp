{
    "version": 2,
    "buildCommand": "cd client && npm run build",
    "outputDirectory": "client/dist",
    "installCommand": "npm run install:all",
    "env": {
        "VITE_API_URL": "@vite_api_url"
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://south-new-system.onrender.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}